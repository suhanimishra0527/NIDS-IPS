# Server environment — copy to /etc/nids/server.env and fill in values
DATABASE_URL=postgresql://nids_user:changeme@localhost:5432/nids_db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
AGENT_REGISTRATION_KEY=changeme
PORT=5000
HOST=0.0.0.0
DEBUG=true
HEARTBEAT_TIMEOUT_SECONDS=90
AUTO_BLOCK_THREAT_SCORE=80
BLOCKLIST_EXPIRY_SECONDS=86400

# Optional HTTPS (leave empty to use plain HTTP)
SSL_CERT=
SSL_KEY=
