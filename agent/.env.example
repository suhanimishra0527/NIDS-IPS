# Agent environment — copy to /etc/nids/agent.env and fill in values
SERVER_URL=http://YOUR_SERVER_IP:5000
AGENT_NAME=agent-1
AGENT_TOKEN=YOUR_JWT_TOKEN_FROM_REGISTER
INTERFACE=eth0
OFFLINE_QUEUE_FILE=/opt/nids/agent/offline_queue.jsonl

# Optional tuning
THREAT_SCORE_LOG=30
THREAT_SCORE_DROP=50
THREAT_SCORE_BLOCK=80
BATCH_INTERVAL_SEC=5
BATCH_MAX_ALERTS=10
HEARTBEAT_INTERVAL=30
SYNC_INTERVAL=60
LOCAL_BLOCK_TTL=3600
PORTSCAN_WINDOW_SEC=10
PORTSCAN_THRESHOLD=20
ANOMALY_PPS_THRESHOLD=500
